<!-- registrars.ejs — Registrars page -->

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-6">
  <div>
    <h1 class="font-display text-2xl font-bold text-gray-900">Registrars</h1>
    <p class="text-sm text-gray-500 mt-1">Monitor registrar performance across your ecosystem.</p>
  </div>
  <!-- <button class="flex items-center gap-1.5 bg-green-600 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-green-700 transition-colors shadow-sm self-start sm:self-auto flex-shrink-0">
    <span class="material-symbols-outlined" style="font-size:18px;">add</span>
    Add Registrar
  </button> -->
</div>

<!-- KPI Row -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">

  <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-red-500 flex flex-col justify-between hover:-translate-y-0.5 transition-transform">
    <div class="flex items-center justify-between mb-3">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Total Registrars</p>
      <span class="p-1.5 bg-gray-50 rounded-lg text-gray-500">
        <span class="material-symbols-outlined" style="font-size:20px;">groups</span>
      </span>
    </div>
    <span class="font-display text-3xl font-bold text-gray-900">24</span>
  </div>

  <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-green-400 flex flex-col justify-between hover:-translate-y-0.5 transition-transform">
    <div class="flex items-center justify-between mb-3">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Active Licenses</p>
      <span class="p-1.5 bg-gray-50 rounded-lg text-green-600">
        <span class="material-symbols-outlined" style="font-size:20px;">verified</span>
      </span>
    </div>
    <div class="flex items-end gap-2">
      <span class="font-display text-3xl font-bold text-gray-900">22</span>
      <span class="text-xs font-semibold text-green-700 bg-green-50 px-1.5 py-0.5 rounded flex items-center gap-0.5 mb-0.5">
        <span class="material-symbols-outlined" style="font-size:12px;">arrow_upward</span>2
      </span>
    </div>
  </div>

  <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-blue-300 flex flex-col justify-between hover:-translate-y-0.5 transition-transform">
    <div class="flex items-center justify-between mb-3">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Monthly Growth</p>
      <span class="p-1.5 bg-gray-50 rounded-lg text-blue-500">
        <span class="material-symbols-outlined" style="font-size:20px;">trending_up</span>
      </span>
    </div>
    <span class="font-display text-3xl font-bold text-gray-900">+8%</span>
  </div>

  <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-gray-300 flex flex-col justify-between hover:-translate-y-0.5 transition-transform">
    <div class="flex items-center justify-between mb-3">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Compliance Rate</p>
      <span class="p-1.5 bg-gray-50 rounded-lg text-gray-500">
        <span class="material-symbols-outlined" style="font-size:20px;">fact_check</span>
      </span>
    </div>
    <span class="font-display text-3xl font-bold text-gray-900">96%</span>
  </div>

</div>

<!-- Table Card -->
<div class="bg-white rounded-xl shadow-sm overflow-hidden">

  <!-- Table Controls -->
  <div class="px-6 py-4 border-b border-gray-100 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
    <div class="relative w-full sm:w-64">
      <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" style="font-size:18px;">search</span>
      <input
        type="text"
        placeholder="Search registrars…"
        class="w-full pl-9 pr-4 py-2 border border-gray-200 bg-gray-50 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-green-600 focus:border-green-600"
      />
    </div>
    <div class="flex items-center gap-2 overflow-x-auto">
      <button class="px-4 py-1.5 rounded-full bg-gray-900 text-white text-xs font-semibold whitespace-nowrap">All</button>
      <button class="px-4 py-1.5 rounded-full border border-gray-200 text-gray-500 hover:bg-gray-50 text-xs font-semibold whitespace-nowrap transition-colors">Accredited</button>
      <button class="px-4 py-1.5 rounded-full border border-gray-200 text-gray-500 hover:bg-gray-50 text-xs font-semibold whitespace-nowrap transition-colors">Gold</button>
      <button class="px-4 py-1.5 rounded-full border border-gray-200 text-gray-500 hover:bg-gray-50 text-xs font-semibold whitespace-nowrap transition-colors">Suspended</button>
    </div>
  </div>

  <!-- Table -->
  <div class="overflow-x-auto">
    <table class="w-full text-left text-sm min-w-[720px]">
      <thead>
        <tr class="bg-gray-50 border-b border-gray-100">
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Registrar Name</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Tier</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400 text-right">Assigned Domains</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400 text-right">Renewal Rate</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400 text-center">Status</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400 text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <%
          const registrars = [
            { initials: 'AN', name: 'AfricaNet Tech',    tier: 'Gold',       tierDot: 'bg-amber-400',  domains: '1,245', renewal: '89%', status: 'Active',    suspended: false, pending: false },
            { initials: 'SH', name: 'Savanna Host',      tier: 'Silver',     tierDot: 'bg-slate-300',  domains: '532',   renewal: '92%', status: 'Active',    suspended: false, pending: false },
            { initials: 'PD', name: 'Prime Domains KE',  tier: 'Platinum',   tierDot: 'bg-slate-800',  domains: '3,890', renewal: '96%', status: 'Active',    suspended: false, pending: false },
            { initials: 'EL', name: 'Equator Links',     tier: 'Accredited', tierDot: 'bg-gray-300',   domains: '12',    renewal: '45%', status: 'Suspended', suspended: true,  pending: false },
            { initials: 'NW', name: 'Nairobi Web',       tier: 'Accredited', tierDot: 'bg-gray-300',   domains: '0',     renewal: '—',   status: 'Pending',   suspended: false, pending: true  },
          ];
        %>
        <% registrars.forEach(function(r) { %>
        <tr class="hover:bg-gray-50 transition-colors <%= r.suspended ? 'opacity-70' : '' %>">

          <!-- Name -->
          <td class="px-6 py-4">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-gray-100 border border-gray-200 flex items-center justify-center flex-shrink-0">
                <span class="text-xs font-bold text-gray-500"><%= r.initials %></span>
              </div>
              <span class="font-semibold <%= r.suspended ? 'text-gray-400' : 'text-gray-900' %>"><%= r.name %></span>
            </div>
          </td>

          <!-- Tier -->
          <td class="px-6 py-4">
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-semibold bg-gray-50 border border-gray-200 text-gray-700">
              <span class="w-1.5 h-3 rounded-full <%= r.tierDot %> inline-block"></span>
              <%= r.tier %>
            </span>
          </td>

          <!-- Domains -->
          <td class="px-6 py-4 text-right font-mono text-gray-700"><%= r.domains %></td>

          <!-- Renewal -->
          <td class="px-6 py-4 text-right font-mono <%= r.suspended ? 'text-red-400' : 'text-gray-700' %>"><%= r.renewal %></td>

          <!-- Status -->
          <td class="px-6 py-4 text-center">
            <% if (r.status === 'Active') { %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-50 text-green-700">Active</span>
            <% } else if (r.status === 'Suspended') { %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-red-50 text-red-600">Suspended</span>
            <% } else { %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-500">Pending</span>
            <% } %>
          </td>

          <!-- Actions -->
          <td class="px-6 py-4 text-right">
            <button class="text-gray-400 hover:text-gray-700 transition-colors p-1 rounded hover:bg-gray-100">
              <span class="material-symbols-outlined" style="font-size:20px;">more_vert</span>
            </button>
          </td>

        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <div class="px-6 py-3 border-t border-gray-100 bg-gray-50 flex items-center justify-between">
    <p class="text-xs text-gray-400">
      Showing <span class="font-semibold text-gray-700">1</span> to <span class="font-semibold text-gray-700">5</span> of <span class="font-semibold text-gray-700">24</span> results
    </p>
    <div class="flex items-center gap-1">
      <button class="p-1.5 rounded hover:bg-gray-200 text-gray-400 disabled:opacity-40 transition-colors" disabled>
        <span class="material-symbols-outlined" style="font-size:18px;">chevron_left</span>
      </button>
      <button class="w-7 h-7 rounded bg-gray-900 text-white text-xs font-semibold flex items-center justify-center">1</button>
      <button class="w-7 h-7 rounded hover:bg-gray-100 text-gray-600 text-xs font-semibold flex items-center justify-center transition-colors">2</button>
      <button class="w-7 h-7 rounded hover:bg-gray-100 text-gray-600 text-xs font-semibold flex items-center justify-center transition-colors">3</button>
      <button class="p-1.5 rounded hover:bg-gray-200 text-gray-500 transition-colors">
        <span class="material-symbols-outlined" style="font-size:18px;">chevron_right</span>
      </button>
    </div>
  </div>

</div>
