  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@400,0&display=swap" rel="stylesheet"/>
  <style>
    body { font-family: 'Inter', sans-serif; }
    .font-display { font-family: 'Plus Jakarta Sans', sans-serif; }
    .material-symbols-outlined { font-family: 'Material Symbols Outlined'; font-style: normal; font-size: 20px; line-height: 1; display: inline-block; vertical-align: middle; }
    .bar-track { position: relative; height: 10px; background: #E5E7EB; border-radius: 4px; overflow: hidden; }
    .bar-fill-green  { position: absolute; top:0; left:0; height:100%; background:#16A34A; border-radius:4px; }
    .bar-fill-amber  { position: absolute; top:0; left:0; height:100%; background:#D97706; border-radius:4px; }
    .bar-fill-red    { position: absolute; top:0; left:0; height:100%; background:#DC2626; border-radius:4px; }
    .bar-fill-gray   { position: absolute; top:0; left:0; height:100%; background:#9CA3AF; border-radius:4px; }
    .badge-green { display:inline-flex; align-items:center; gap:2px; font-size:11px; font-weight:600; color:#15803D; background:#F0FDF4; padding:2px 7px; border-radius:4px; }
    .badge-red   { display:inline-flex; align-items:center; gap:2px; font-size:11px; font-weight:600; color:#B91C1C; background:#FEF2F2; padding:2px 7px; border-radius:4px; }
    .badge-amber { display:inline-flex; align-items:center; gap:2px; font-size:11px; font-weight:600; color:#B45309; background:#FFFBEB; padding:2px 7px; border-radius:4px; }
    .treemap-cell { display:flex; align-items:center; justify-content:center; text-align:center; color:#fff; font-family:'Inter',sans-serif; font-size:11px; font-weight:600; padding:4px; border-radius:4px; cursor:pointer; transition:opacity .15s; }
    .treemap-cell:hover { opacity:.85; }
    .section-label { font-size:11px; font-weight:700; letter-spacing:.07em; text-transform:uppercase; color:#6B7280; }
    .tab { display:inline-flex; align-items:center; gap:6px; padding:6px 14px; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; transition:background .15s, color .15s; }
    .tab.active { background:#F0FDF4; color:#15803D; }
    .tab:not(.active) { color:#6B7280; }
    .tab:not(.active):hover { background:#F9FAFB; color:#374151; }
  </style>
</head>
