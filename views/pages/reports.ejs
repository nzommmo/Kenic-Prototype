    .tab:not(.active) { color:#6B7280; }
    .tab:not(.active):hover { background:#F9FAFB; color:#374151; }
    .tab-panel { display:none; }
    .tab-panel.active-panel { display:flex; flex-direction:column; gap:24px; }
    .kpi-card { background:#fff; border:1px solid #F3F4F6; border-radius:12px; padding:14px; box-shadow:0 1px 2px rgba(0,0,0,.03); display:flex; flex-direction:column; gap:6px; }
