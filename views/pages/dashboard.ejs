<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>KeNIC Partner Portal – Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@400,0&display=swap" rel="stylesheet"/>
  <style>
    body { font-family: 'Inter', sans-serif; }
    .font-display { font-family: 'Plus Jakarta Sans', sans-serif; }
    .material-symbols-outlined { font-family: 'Material Symbols Outlined'; font-style: normal; font-size: 20px; line-height: 1; display: inline-block; vertical-align: middle; }
    .bar-chart-row { position: relative; height: 8px; background: #E5E7EB; border-radius: 4px; overflow: hidden; }
    .bar-chart-fill-green { position: absolute; top: 0; left: 0; height: 100%; background: #16A34A; border-radius: 4px; }
    .bar-chart-fill-amber { position: absolute; top: 0; left: 0; height: 100%; background: #D97706; border-radius: 4px; }
    .badge-green { display:inline-flex; align-items:center; gap:2px; font-size:11px; font-weight:600; color:#15803D; background:#F0FDF4; padding:2px 6px; border-radius:4px; }
    .badge-amber { display:inline-flex; align-items:center; gap:2px; font-size:11px; font-weight:600; color:#B45309; background:#FFFBEB; padding:2px 6px; border-radius:4px; }
    .badge-red   { display:inline-flex; align-items:center; gap:2px; font-size:11px; font-weight:600; color:#B91C1C; background:#FEF2F2; padding:2px 6px; border-radius:4px; }
  </style>
</head>
<body class="bg-gray-100 text-gray-900 antialiased">

<div class="max-w-6xl mx-auto flex flex-col gap-6 p-6">

  <!-- ── Page Header ── -->
  <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-green-700 mb-1">Partner Ecosystem Portal</p>
      <h1 class="font-display text-2xl font-bold text-gray-900">        Welcome back, <%= userOrg %></h1>
      <p class="text-sm text-gray-500 mt-1">Partnership intelligence overview · Q2 2026</p>
    </div>
    <div class="flex gap-2 flex-shrink-0">
      <button class="flex items-center gap-1.5 border border-gray-200 bg-white text-gray-700 text-sm font-medium px-3 py-2 rounded-lg hover:bg-gray-50 transition-colors shadow-sm">
        <span class="material-symbols-outlined" style="font-size:16px;">calendar_today</span>
        Last 30 Days
        <span class="material-symbols-outlined" style="font-size:16px;">keyboard_arrow_down</span>
      </button>
      <button class="flex items-center gap-1.5 border border-gray-200 bg-white text-gray-700 text-sm font-medium px-3 py-2 rounded-lg hover:bg-gray-50 transition-colors shadow-sm">
        <span class="material-symbols-outlined" style="font-size:16px;">download</span>
        Export
      </button>
    </div>
  </div>

  <!-- ── Row 1: Partnership Impact Score + KPI Grid ── -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- Partnership Impact Score -->
    <div class="bg-white rounded-xl p-6 shadow-sm border-l-4 border-green-600 flex flex-col justify-between">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="font-display text-base font-bold text-gray-900">Partnership Impact Score</h2>
          <p class="text-xs text-gray-400 mt-0.5">Composite ecosystem intelligence</p>
        </div>
        <button class="text-gray-400 hover:text-gray-600">
          <span class="material-symbols-outlined" style="font-size:18px;">more_vert</span>
        </button>
      </div>
      <div class="flex items-center gap-6">
        <!-- Gauge -->
        <div class="relative w-28 h-28 flex-shrink-0">
          <svg class="w-full h-full -rotate-90" viewBox="0 0 100 100">
            <circle cx="50" cy="50" r="40" fill="none" stroke="#F3F4F6" stroke-width="12"/>
            <circle cx="50" cy="50" r="40" fill="none" stroke="#16A34A"
                    stroke-width="12" stroke-dasharray="251.3" stroke-dashoffset="40.2" stroke-linecap="round"/>
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
            <span class="text-2xl font-bold font-display text-green-700">84</span>
            <span class="text-xs text-gray-400">/ 100</span>
          </div>
        </div>
        <!-- Breakdown bars -->
        <div class="flex-1 space-y-3">
          <div>
            <div class="flex justify-between mb-1">
              <span class="text-xs text-gray-500">Initiative Completion</span>
              <span class="text-xs font-semibold text-green-700">92%</span>
            </div>
            <div class="bar-chart-row"><div class="bar-chart-fill-green" style="width:92%"></div></div>
          </div>
          <div>
            <div class="flex justify-between mb-1">
              <span class="text-xs text-gray-500">Ecosystem Contribution</span>
              <span class="text-xs font-semibold text-green-700">88%</span>
            </div>
            <div class="bar-chart-row"><div class="bar-chart-fill-green" style="width:88%"></div></div>
          </div>
          <div>
            <div class="flex justify-between mb-1">
              <span class="text-xs text-gray-500">Strategic Engagement</span>
              <span class="text-xs font-semibold text-amber-600">72%</span>
            </div>
            <div class="bar-chart-row"><div class="bar-chart-fill-amber" style="width:72%;"></div></div>
          </div>
        </div>
      </div>
      <!-- Ecosystem rank -->
      <div class="mt-5 pt-4 border-t border-gray-100 flex items-center justify-between">
        <span class="text-xs text-gray-400">Ecosystem rank among partners</span>
        <span class="text-xs font-bold text-green-700 bg-green-50 px-2 py-0.5 rounded">#3 of 47</span>
      </div>
    </div>

    <!-- KPI Cards -->
    <div class="lg:col-span-2 grid grid-cols-2 md:grid-cols-3 gap-6">

      <!-- Ecosystem Reach -->
      <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-green-600 flex flex-col justify-center">
        <div class="flex items-center gap-1.5 text-gray-500 mb-2">
          <span class="material-symbols-outlined" style="font-size:16px;">radar</span>
          <span class="text-xs font-semibold uppercase tracking-wider">Reach</span>
        </div>
        <div class="flex items-end gap-2">
          <span class="font-display text-2xl font-bold text-gray-900">284K</span>
          <span class="badge-green mb-0.5">
            <span class="material-symbols-outlined" style="font-size:12px;">arrow_upward</span>34%
          </span>
        </div>
        <p class="text-xs text-gray-400 mt-1">Ecosystem impressions</p>
      </div>

      <!-- Active Collaborations -->
      <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-green-600 flex flex-col justify-center">
        <div class="flex items-center gap-1.5 text-gray-500 mb-2">
          <span class="material-symbols-outlined" style="font-size:16px;">handshake</span>
          <span class="text-xs font-semibold uppercase tracking-wider">Collaborations</span>
        </div>
        <div class="flex items-end gap-2">
          <span class="font-display text-2xl font-bold text-gray-900">12</span>
          <span class="badge-green mb-0.5">
            <span class="material-symbols-outlined" style="font-size:12px;">arrow_upward</span>3 new
          </span>
        </div>
        <p class="text-xs text-gray-400 mt-1">Active initiatives</p>
      </div>

      <!-- Ecosystem Contribution -->
      <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-green-600 flex flex-col justify-center">
        <div class="flex items-center gap-1.5 text-gray-500 mb-2">
          <span class="material-symbols-outlined" style="font-size:16px;">public</span>
          <span class="text-xs font-semibold uppercase tracking-wider">Contribution</span>
        </div>
        <div class="flex items-end gap-2">
          <span class="font-display text-2xl font-bold text-gray-900">342</span>
          <span class="badge-green mb-0.5">
            <span class="material-symbols-outlined" style="font-size:12px;">arrow_upward</span>18%
          </span>
        </div>
        <p class="text-xs text-gray-400 mt-1">Ecosystem referrals influenced</p>
      </div>

      <!-- Community Impact -->
      <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-green-600 flex flex-col justify-center">
        <div class="flex items-center gap-1.5 text-gray-500 mb-2">
          <span class="material-symbols-outlined" style="font-size:16px;">groups</span>
          <span class="text-xs font-semibold uppercase tracking-wider">Community</span>
        </div>
        <div class="flex items-end gap-2">
          <span class="font-display text-2xl font-bold text-gray-900">6.2K</span>
          <span class="badge-green mb-0.5">
            <span class="material-symbols-outlined" style="font-size:12px;">arrow_upward</span>22%
          </span>
        </div>
        <p class="text-xs text-gray-400 mt-1">SMEs &amp; students reached</p>
      </div>

      <!-- Opportunity Engagement — spans 2 cols -->
      <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-amber-500 flex flex-col justify-center md:col-span-2">
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-1.5 text-gray-500">
            <span class="material-symbols-outlined" style="font-size:16px;">notifications_active</span>
            <span class="text-xs font-semibold uppercase tracking-wider">Opportunity Engagement</span>
          </div>
          <span class="badge-amber">
            <span class="material-symbols-outlined" style="font-size:12px;">schedule</span>5 pending
          </span>
        </div>
        <div class="flex items-end justify-between">
          <div>
            <span class="font-display text-2xl font-bold text-gray-900">68%</span>
            <span class="text-sm text-gray-400 ml-1">Participation rate</span>
          </div>
          <button class="text-xs text-amber-600 font-semibold underline hover:text-amber-800">Review opportunities →</button>
        </div>
        <div class="mt-3 bar-chart-row"><div class="bar-chart-fill-amber" style="width:68%"></div></div>
      </div>

    </div>
  </div>

  <!-- ── Row 2: Reach Trend + Collaboration Status ── -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- Ecosystem Reach Trend -->
    <div class="lg:col-span-2 bg-white rounded-xl p-6 shadow-sm border-l-4 border-green-600">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between border-b border-gray-100 pb-4 mb-6 gap-2">
        <div>
          <h2 class="font-display text-lg font-bold text-gray-900">Ecosystem Reach Trend</h2>
          <p class="text-xs text-gray-400 mt-0.5">12-Month campaign &amp; community outreach (Jul '25 – Jun '26)</p>
        </div>
        <div class="flex items-center gap-4 flex-shrink-0">
          <span class="flex items-center gap-1.5 text-xs text-gray-500">
            <span class="w-2.5 h-2.5 rounded-full bg-green-600 inline-block"></span>Campaign Reach
          </span>
          <span class="flex items-center gap-1.5 text-xs text-gray-500">
            <span class="w-2.5 h-2.5 rounded-full bg-gray-300 inline-block"></span>Community Outreach
          </span>
        </div>
      </div>
      <div class="relative h-52">
        <div class="absolute left-0 top-0 bottom-4 flex flex-col justify-between text-right pr-2" style="width:36px">
          <span class="text-[10px] text-gray-400">400K</span>
          <span class="text-[10px] text-gray-400">300K</span>
          <span class="text-[10px] text-gray-400">200K</span>
          <span class="text-[10px] text-gray-400">100K</span>
          <span class="text-[10px] text-gray-400">0</span>
        </div>
        <div class="absolute left-10 right-0 top-0 bottom-6">
          <div class="absolute inset-0 flex flex-col justify-between pointer-events-none">
            <div class="w-full border-t border-dashed border-gray-100"></div>
            <div class="w-full border-t border-dashed border-gray-100"></div>
            <div class="w-full border-t border-dashed border-gray-100"></div>
            <div class="w-full border-t border-dashed border-gray-100"></div>
            <div class="w-full border-t border-gray-200"></div>
          </div>
          <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="none" viewBox="0 0 100 100">
            <defs>
              <linearGradient id="reachGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" style="stop-color:#16A34A;stop-opacity:0.18"/>
                <stop offset="100%" style="stop-color:#16A34A;stop-opacity:0"/>
              </linearGradient>
            </defs>
            <path d="M0,100 L0,72 Q10,62 20,66 T40,50 T60,32 T80,42 T100,22 L100,100 Z" fill="url(#reachGrad)"/>
            <path d="M0,72 Q10,62 20,66 T40,50 T60,32 T80,42 T100,22" fill="none" stroke="#16A34A" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M0,82 Q15,86 30,76 T60,82 T100,62" fill="none" stroke="#D1D5DB" stroke-dasharray="4,4" stroke-width="1.5"/>
          </svg>
        </div>
        <div class="absolute bottom-0 left-10 right-0 flex justify-between">
          <span class="text-[10px] text-gray-400">Jul</span>
          <span class="text-[10px] text-gray-400">Sep</span>
          <span class="text-[10px] text-gray-400">Nov</span>
          <span class="text-[10px] text-gray-400">Jan</span>
          <span class="text-[10px] text-gray-400">Mar</span>
          <span class="text-[10px] text-gray-400">May</span>
          <span class="text-[10px] text-gray-400">Jun</span>
        </div>
      </div>
    </div>

    <!-- Collaboration Status Donut -->
    <div class="bg-white rounded-xl p-6 shadow-sm border-l-4 border-green-600">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-display text-lg font-bold text-gray-900">Collaboration Status</h2>
        <button class="text-gray-400 hover:text-gray-600">
          <span class="material-symbols-outlined" style="font-size:18px;">filter_list</span>
        </button>
      </div>
      <div class="flex flex-col items-center gap-6">
        <div class="relative w-36 h-36 flex-shrink-0">
          <svg class="w-full h-full -rotate-90" viewBox="0 0 100 100">
            <!-- Completed: 58% -->
            <circle cx="50" cy="50" r="38" fill="none" stroke="#16A34A"
                    stroke-width="14" stroke-dasharray="138.4 238.9"/>
            <!-- In Progress: 25% -->
            <circle cx="50" cy="50" r="38" fill="none" stroke="#4ADE80"
                    stroke-width="14" stroke-dasharray="59.7 238.9" stroke-dashoffset="-138.4"/>
            <!-- Pending: 10% -->
            <circle cx="50" cy="50" r="38" fill="none" stroke="#D97706"
                    stroke-width="14" stroke-dasharray="23.9 238.9" stroke-dashoffset="-198.1"/>
            <!-- Overdue: 7% -->
            <circle cx="50" cy="50" r="38" fill="none" stroke="#FCA5A5"
                    stroke-width="14" stroke-dasharray="16.7 238.9" stroke-dashoffset="-222"/>
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center text-center pointer-events-none">
            <span class="font-display text-lg font-bold text-gray-900">19</span>
            <span class="text-[9px] font-semibold uppercase tracking-widest text-gray-400">Initiatives</span>
          </div>
        </div>
        <div class="w-full space-y-2.5">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-green-600 inline-block flex-shrink-0"></span><span class="text-xs text-gray-700">Completed</span></div>
            <span class="text-xs font-semibold text-gray-500">11 · 58%</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-green-300 inline-block flex-shrink-0"></span><span class="text-xs text-gray-700">In Progress</span></div>
            <span class="text-xs font-semibold text-gray-500">5 · 25%</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-amber-500 inline-block flex-shrink-0"></span><span class="text-xs text-gray-700">Pending</span></div>
            <span class="text-xs font-semibold text-gray-500">2 · 10%</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-red-200 inline-block flex-shrink-0"></span><span class="text-xs text-gray-700">Overdue</span></div>
            <span class="text-xs font-semibold text-red-500">1 · 7%</span>
          </div>
        </div>
        <a href="#" class="w-full text-center text-xs font-semibold text-green-700 hover:text-green-900 border border-green-200 rounded-lg py-2 transition-colors">View all initiatives →</a>
      </div>
    </div>
  </div>

  <!-- ── Row 3: Community Impact Snapshot ── -->
  <div class="bg-white rounded-xl p-6 shadow-sm border-l-4 border-green-600">
    <div class="flex items-center justify-between mb-5">
      <div>
        <h2 class="font-display text-lg font-bold text-gray-900">Community Impact Snapshot</h2>
        <p class="text-xs text-gray-400 mt-0.5">Real-world ecosystem enablement · Q2 2026</p>
      </div>
      <a href="#" class="text-xs font-semibold text-green-700 hover:text-green-900 underline">Full report →</a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-gray-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold font-display text-gray-900">1,240</div>
        <div class="text-xs text-gray-500 mt-1 flex items-center justify-center gap-1">
          <span class="material-symbols-outlined" style="font-size:14px;">store</span>SMEs Reached
        </div>
      </div>
      <div class="bg-gray-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold font-display text-gray-900">4,980</div>
        <div class="text-xs text-gray-500 mt-1 flex items-center justify-center gap-1">
          <span class="material-symbols-outlined" style="font-size:14px;">school</span>Students Trained
        </div>
      </div>
      <div class="bg-gray-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold font-display text-gray-900">18</div>
        <div class="text-xs text-gray-500 mt-1 flex items-center justify-center gap-1">
          <span class="material-symbols-outlined" style="font-size:14px;">location_on</span>Counties Engaged
        </div>
      </div>
      <div class="bg-gray-50 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold font-display text-gray-900">320</div>
        <div class="text-xs text-gray-500 mt-1 flex items-center justify-center gap-1">
          <span class="material-symbols-outlined" style="font-size:14px;">code</span>Developers Onboarded
        </div>
      </div>
    </div>
  </div>

</div>
</body>
</html>