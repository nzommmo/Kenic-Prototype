<!-- domains.ejs — Domain Attribution page -->

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-6">
  <div>
    <h1 class="font-display text-2xl font-bold text-gray-900">Domain Attribution</h1>
    <p class="text-sm text-gray-500 mt-1">Deep-dive view for <%= userOrg %>.</p>
  </div>
  <div class="flex items-center gap-2 flex-shrink-0">
    <select class="border border-gray-200 bg-white rounded-lg text-sm font-medium py-2 pl-3 pr-8 shadow-sm focus:outline-none focus:ring-1 focus:ring-green-600">
      <option>Last 30 Days</option>
      <option>Last Quarter</option>
      <option>Year to Date</option>
    </select>
    <button class="flex items-center gap-1.5 border border-gray-200 bg-white text-gray-700 text-sm font-medium px-3 py-2 rounded-lg hover:bg-gray-50 transition-colors shadow-sm">
      <span class="material-symbols-outlined" style="font-size:16px;">download</span>
      Export
    </button>
  </div>
</div>

<!-- KPI Row -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">

  <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-green-600 flex flex-col justify-between">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">Domains Attributed (MTD)</p>
    <div class="flex items-end justify-between">
      <span class="font-display text-3xl font-bold text-gray-900">342</span>
      <span class="text-xs font-semibold text-green-700 bg-green-50 px-2 py-1 rounded flex items-center gap-0.5">
        <span class="material-symbols-outlined" style="font-size:13px;">trending_up</span>+18%
      </span>
    </div>
  </div>

  <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-red-500 flex flex-col justify-between">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">Renewal Rate</p>
    <div class="flex items-end justify-between">
      <span class="font-display text-3xl font-bold text-gray-900">87.4%</span>
      <span class="text-xs font-semibold text-red-600 bg-red-50 px-2 py-1 rounded flex items-center gap-0.5">
        <span class="material-symbols-outlined" style="font-size:13px;">trending_down</span>-1.2%
      </span>
    </div>
  </div>

  <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-red-500 flex flex-col justify-between">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">At-Risk (30 Days)</p>
    <div class="flex items-end justify-between">
      <span class="font-display text-3xl font-bold text-gray-900">43</span>
      <span class="text-xs font-semibold text-red-600 bg-red-50 px-2 py-1 rounded">Action Req.</span>
    </div>
  </div>

  <div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-gray-200 flex flex-col justify-between">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">Churned (QTD)</p>
    <div class="flex items-end justify-between">
      <span class="font-display text-3xl font-bold text-gray-900">18</span>
    </div>
  </div>

</div>

<!-- Charts Grid -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

  <!-- Monthly Attribution Trend -->
  <div class="bg-white rounded-xl p-6 shadow-sm border-l-4 border-green-600">
    <div class="flex items-center justify-between mb-5">
      <div>
        <h2 class="font-display text-base font-bold text-gray-900">Monthly Attribution Trend</h2>
        <p class="text-xs text-gray-400 mt-0.5">Jul '25 – Jun '26</p>
      </div>
      <div class="flex items-center gap-3">
        <span class="flex items-center gap-1.5 text-xs text-gray-500"><span class="w-2.5 h-2.5 rounded-full bg-green-600 inline-block"></span>.ke</span>
        <span class="flex items-center gap-1.5 text-xs text-gray-500"><span class="w-2.5 h-2.5 rounded-full bg-gray-300 inline-block"></span>Other</span>
      </div>
    </div>
    <div class="relative h-52">
      <div class="absolute left-0 top-0 bottom-4 flex flex-col justify-between text-right pr-2" style="width:32px">
        <span class="text-[10px] text-gray-400">400</span>
        <span class="text-[10px] text-gray-400">300</span>
        <span class="text-[10px] text-gray-400">200</span>
        <span class="text-[10px] text-gray-400">100</span>
        <span class="text-[10px] text-gray-400">0</span>
      </div>
      <div class="absolute left-9 right-0 top-0 bottom-6">
        <div class="absolute inset-0 flex flex-col justify-between pointer-events-none">
          <div class="w-full border-t border-dashed border-gray-100"></div>
          <div class="w-full border-t border-dashed border-gray-100"></div>
          <div class="w-full border-t border-dashed border-gray-100"></div>
          <div class="w-full border-t border-dashed border-gray-100"></div>
          <div class="w-full border-t border-gray-200"></div>
        </div>
        <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="none" viewBox="0 0 100 100">
          <defs>
            <linearGradient id="areaGrad" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" style="stop-color:#16A34A;stop-opacity:0.15"/>
              <stop offset="100%" style="stop-color:#16A34A;stop-opacity:0"/>
            </linearGradient>
          </defs>
          <path d="M0,100 L0,75 C10,65 15,60 25,55 S40,45 55,35 S75,38 90,28 L100,20 L100,100 Z" fill="url(#areaGrad)"/>
          <path d="M0,75 C10,65 15,60 25,55 S40,45 55,35 S75,38 90,28 L100,20" fill="none" stroke="#16A34A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M0,85 C15,88 30,78 50,82 T100,65" fill="none" stroke="#D1D5DB" stroke-dasharray="4,4" stroke-width="1.5"/>
        </svg>
      </div>
      <div class="absolute bottom-0 left-9 right-0 flex justify-between">
        <span class="text-[10px] text-gray-400">Jul</span><span class="text-[10px] text-gray-400">Sep</span>
        <span class="text-[10px] text-gray-400">Nov</span><span class="text-[10px] text-gray-400">Jan</span>
        <span class="text-[10px] text-gray-400">Mar</span><span class="text-[10px] text-gray-400">May</span>
        <span class="text-[10px] text-gray-400">Jun</span>
      </div>
    </div>
  </div>

  <!-- Extension Breakdown Stacked Bar -->
  <div class="bg-white rounded-xl p-6 shadow-sm border-l-4 border-green-600">
    <div class="flex items-center justify-between mb-5">
      <div>
        <h2 class="font-display text-base font-bold text-gray-900">Extension Breakdown</h2>
        <p class="text-xs text-gray-400 mt-0.5">By TLD, last 6 months</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <span class="flex items-center gap-1 text-[10px] text-gray-500"><span class="w-2 h-2 rounded-sm bg-green-600 inline-block"></span>.co.ke</span>
        <span class="flex items-center gap-1 text-[10px] text-gray-500"><span class="w-2 h-2 rounded-sm bg-green-300 inline-block"></span>.or.ke</span>
        <span class="flex items-center gap-1 text-[10px] text-gray-500"><span class="w-2 h-2 rounded-sm bg-gray-300 inline-block"></span>.ke</span>
        <span class="flex items-center gap-1 text-[10px] text-gray-500"><span class="w-2 h-2 rounded-sm bg-gray-200 inline-block"></span>Other</span>
      </div>
    </div>
    <!-- Stacked bars -->
    <div class="flex items-end justify-between gap-2 h-44 mt-2">
      <% 
        const barData = [
          { label: 'Jan', co: 58, or: 18, ke: 14, other: 10 },
          { label: 'Feb', co: 60, or: 19, ke: 12, other: 9  },
          { label: 'Mar', co: 55, or: 22, ke: 13, other: 10 },
          { label: 'Apr', co: 62, or: 17, ke: 12, other: 9  },
          { label: 'May', co: 63, or: 20, ke: 10, other: 7  },
          { label: 'Jun', co: 60, or: 20, ke: 10, other: 10 },
        ];
      %>
      <% barData.forEach(function(b) { %>
      <div class="flex-1 flex flex-col items-center gap-1">
        <div class="w-full flex flex-col-reverse rounded-sm overflow-hidden" style="height: 140px;">
          <div class="w-full bg-green-600"        style="height:<%= b.co %>%"></div>
          <div class="w-full bg-green-300"        style="height:<%= b.or %>%"></div>
          <div class="w-full bg-gray-300"         style="height:<%= b.ke %>%"></div>
          <div class="w-full bg-gray-100 border-t border-gray-200" style="height:<%= b.other %>%"></div>
        </div>
        <span class="text-[10px] text-gray-400"><%= b.label %></span>
      </div>
      <% }); %>
    </div>
  </div>

  <!-- Registrant Type Mix Donut -->
  <div class="bg-white rounded-xl p-6 shadow-sm border-l-4 border-green-600">
    <div class="flex items-center justify-between mb-5">
      <div>
        <h2 class="font-display text-base font-bold text-gray-900">Registrant Type Mix</h2>
        <p class="text-xs text-gray-400 mt-0.5">By entity category</p>
      </div>
    </div>
    <div class="flex items-center gap-8 justify-center">
      <div class="relative w-36 h-36 flex-shrink-0">
        <svg class="w-full h-full -rotate-90" viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="38" fill="none" stroke="#16A34A" stroke-width="14" stroke-dasharray="143.3 238.9"/>
          <circle cx="50" cy="50" r="38" fill="none" stroke="#4ADE80" stroke-width="14" stroke-dasharray="71.7 238.9" stroke-dashoffset="-143.3"/>
          <circle cx="50" cy="50" r="38" fill="none" stroke="#D1D5DB" stroke-width="14" stroke-dasharray="47.8 238.9" stroke-dashoffset="-215"/>
          <circle cx="50" cy="50" r="38" fill="none" stroke="#F3F4F6" stroke-width="14" stroke-dasharray="23.9 238.9" stroke-dashoffset="-262.8"/>
        </svg>
        <div class="absolute inset-0 flex flex-col items-center justify-center text-center pointer-events-none">
          <span class="font-display text-lg font-bold text-gray-900">342</span>
          <span class="text-[9px] font-semibold uppercase tracking-widest text-gray-400">Total</span>
        </div>
      </div>
      <div class="space-y-2.5">
        <div class="flex items-center justify-between gap-6">
          <div class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-green-600 inline-block"></span><span class="text-xs text-gray-700">SME</span></div>
          <span class="text-xs font-semibold text-gray-500">60%</span>
        </div>
        <div class="flex items-center justify-between gap-6">
          <div class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-green-300 inline-block"></span><span class="text-xs text-gray-700">Corporate</span></div>
          <span class="text-xs font-semibold text-gray-500">30%</span>
        </div>
        <div class="flex items-center justify-between gap-6">
          <div class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-gray-300 inline-block"></span><span class="text-xs text-gray-700">NGO / Gov</span></div>
          <span class="text-xs font-semibold text-gray-500">20%</span>
        </div>
        <div class="flex items-center justify-between gap-6">
          <div class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-gray-100 border border-gray-200 inline-block"></span><span class="text-xs text-gray-700">Individual</span></div>
          <span class="text-xs font-semibold text-gray-500">10%</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Renewal Cohort Health -->
  <div class="bg-white rounded-xl p-6 shadow-sm border-l-4 border-green-600">
    <div class="flex items-center justify-between mb-5">
      <div>
        <h2 class="font-display text-base font-bold text-gray-900">Renewal Cohort Health</h2>
        <p class="text-xs text-gray-400 mt-0.5">Renewed vs. lapsed by quarter</p>
      </div>
      <div class="flex gap-3">
        <span class="flex items-center gap-1.5 text-[10px] text-gray-500"><span class="w-2.5 h-2.5 rounded-sm bg-green-600 inline-block"></span>Renewed</span>
        <span class="flex items-center gap-1.5 text-[10px] text-gray-500"><span class="w-2.5 h-2.5 rounded-sm bg-red-300 inline-block"></span>Lapsed</span>
      </div>
    </div>
    <%
      const cohorts = [
        { label: 'Q3 '24', renewed: 88, lapsed: 12 },
        { label: 'Q4 '24', renewed: 91, lapsed: 9  },
        { label: 'Q1 '25', renewed: 85, lapsed: 15 },
        { label: 'Q2 '25', renewed: 87, lapsed: 13 },
      ];
    %>
    <div class="space-y-3 mt-2">
      <% cohorts.forEach(function(c) { %>
      <div>
        <div class="flex justify-between mb-1">
          <span class="text-xs font-medium text-gray-600"><%= c.label %></span>
          <span class="text-xs text-gray-400"><span class="text-green-700 font-semibold"><%= c.renewed %>%</span> renewed</span>
        </div>
        <div class="flex w-full h-3 rounded-full overflow-hidden">
          <div class="bg-green-600 h-full" style="width:<%= c.renewed %>%"></div>
          <div class="bg-red-300 h-full" style="width:<%= c.lapsed %>%"></div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>

</div>

<!-- At-Risk Domains Table -->
<div class="bg-white rounded-xl shadow-sm overflow-hidden mb-6">
  <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
    <h2 class="font-display text-base font-bold text-gray-900">At-Risk Domains</h2>
    <button class="text-xs font-semibold text-red-600 hover:underline">View All</button>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-left text-sm">
      <thead>
        <tr class="bg-gray-50 border-b border-gray-100">
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Domain</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Extension</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Expiry Date</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Days Left</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Auto-Renew</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400">Status</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-400 text-right">Action</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <%
          const atRisk = [
            { domain: 'safaricom-shop.co.ke',        ext: '.co.ke', expiry: '2023-11-02', days: 5,  autoRenew: false, critical: true  },
            { domain: 'm-pesa-api.ke',               ext: '.ke',    expiry: '2023-11-05', days: 8,  autoRenew: false, critical: true  },
            { domain: 'safaricom-foundation.or.ke',  ext: '.or.ke', expiry: '2023-11-15', days: 18, autoRenew: true,  critical: false },
            { domain: 'tech-hub.ac.ke',              ext: '.ac.ke', expiry: '2023-11-21', days: 24, autoRenew: false, critical: false },
          ];
        %>
        <% atRisk.forEach(function(row) { %>
        <tr class="<%= row.critical ? 'bg-red-50 hover:bg-red-100' : 'hover:bg-gray-50' %> transition-colors">
          <td class="px-6 py-4 font-mono font-medium text-gray-900"><%= row.domain %></td>
          <td class="px-6 py-4 text-gray-500"><%= row.ext %></td>
          <td class="px-6 py-4 font-mono text-gray-600"><%= row.expiry %></td>
          <td class="px-6 py-4 font-mono font-bold <%= row.critical ? 'text-red-600' : 'text-gray-500' %>"><%= row.days %></td>
          <td class="px-6 py-4">
            <% if (row.autoRenew) { %>
            <span class="flex items-center gap-1 text-green-600 text-xs font-semibold">
              <span class="material-symbols-outlined" style="font-size:15px;">check_circle</span>On
            </span>
            <% } else { %>
            <span class="flex items-center gap-1 text-gray-400 text-xs">
              <span class="material-symbols-outlined" style="font-size:15px;">cancel</span>Off
            </span>
            <% } %>
          </td>
          <td class="px-6 py-4">
            <% if (row.critical) { %>
            <span class="bg-red-100 text-red-600 text-xs font-semibold px-2 py-1 rounded-full">Critical</span>
            <% } else { %>
            <span class="bg-gray-100 text-gray-500 text-xs font-semibold px-2 py-1 rounded-full">Warning</span>
            <% } %>
          </td>
          <td class="px-6 py-4 text-right">
            <button class="text-xs font-semibold px-3 py-1.5 rounded-lg border transition-colors
              <%= row.critical
                ? 'border-red-500 text-red-600 hover:bg-red-500 hover:text-white'
                : 'border-gray-200 text-gray-600 hover:bg-gray-50' %>">
              Send Reminder
            </button>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
